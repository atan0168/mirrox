{
  "name": "digital-twin-workspace",
  "version": "1.0.0",
  "description": "Digital Twin Air Quality Application Workspace",
  "private": true,
  "scripts": {
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:app": "cd app && npm run format",
    "format:backend": "cd backend && npm run format",
    "lint": "npm run lint:app && npm run lint:backend",
    "lint:app": "cd app && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "install:all": "npm install && cd app && npm install && cd ../backend && npm install"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "playwright": "^1.55.0",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "axios": "^1.12.0",
    "cheerio": "^1.0.0-rc.12",
    "querystring": "^0.2.1"
  }
}
